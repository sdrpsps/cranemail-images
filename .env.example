# SmarterMail Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SMARTERMAIL_URL=https://us1.workspace.org
SMARTERMAIL_CLIENT_ID=cranemail-images-app
PUBLIC_FOLDER=/public
TIMEZONE=Asia/Shanghai

# Cryptographic Key for Password Encryption (AES-256-GCM)
# Recommend generating a secure random string (e.g., via `openssl rand -hex 32`)
ENCRYPTION_KEY=cranemail-images-app-default-development-encryption-key

# Telegram Bot Credentials
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=CraneMailImagesBot

# Turso Cloud Database Configuration
# Leave blank for local SQLite file database fallback (writes to local.db)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
